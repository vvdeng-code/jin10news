GMAIL_USER=yourname@gmail.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_OAUTH_PORT=3000
EMAIL_FROM="jin10 news <yourname@gmail.com>"
EMAIL_TO=team@company.com
EMAIL_SUBJECT_PREFIX=

# Polling interval for immediate alerts.
POLL_INTERVAL_SECONDS=60
JIN10_REQUEST_TIMEOUT_MS=20000
JIN10_REQUEST_RETRIES=2
EMAIL_SEND_TIMEOUT_MS=30000
EMAIL_SEND_RETRIES=2

# Local file to store seen events and history.
STORE_PATH=./data/store.json

# Anthropic API (used for AI-based news classification).
ANTHROPIC_API_KEY=

# Jin10 Data source.
JIN10_SITE_URL=https://www.jin10.com/
JIN10_FLASH_URL=https://flash-api.jin10.com/get_flash_list?channel=-8200&vip=1
